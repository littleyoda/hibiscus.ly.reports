<?xml version="1.0" encoding="UTF-8"?>
<plugin xmlns="http://www.willuhn.de/schema/jameica-plugin"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.willuhn.de/schema/jameica-plugin https://www.willuhn.de/schema/jameica-plugin-1.5.xsd"
        name="hibiscus.ly.reports" version="0.9.0" class="de.open4me.hibiscus.reports.Plugin">

  <description>Interaktive Geldfluss- und Perioden-Auswertungen und Report-Generator für Hibiscus</description>
  <license>GPL-3.0</license>
  <url>https://www.open4me.de/hibiscus/hibiscus.ly.reports/hibiscus.ly.reports.zip</url>

  <requires jameica="2.10.0+">
    <import plugin="hibiscus" version="2.10.0+" />
  </requires>

  <extensions>
    <extension extends="hibiscus.navi.reporting" class="de.open4me.hibiscus.reports.ui.ReportingNavigationExtension" />
    <extension extends="hibiscus.navi" class="de.open4me.hibiscus.reports.ui.ReportsNavigationExtension" />
  </extensions>

  <menu>
    <item id="hibiscus.ly.reports.menu" name="Reports">
      <item id="hibiscus.ly.reports.mcp-settings" name="MCP-Server..." action="de.open4me.hibiscus.reports.ui.McpSettingsAction" />
    </item>
  </menu>

  <classfinder>
    <include>hibiscus\.ly\.reports\.jar</include>
    <include>lib/.*\.jar</include>
    <include>.*\.class</include>
  </classfinder>
</plugin>
